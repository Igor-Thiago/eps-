# Django
SECRET_KEY=sua-chave-secreta-aqui-troque-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=investigacao
DB_USER=pcdf_admin
DB_PASSWORD=pcdf_secure_pass
DB_HOST=db
DB_PORT=5432

# Casos
# Caminho base padrao onde as pastas dos casos serao criadas.
# Se omitido, o sistema usa media/casos dentro do projeto.
CASES_ROOT=/app/media/casos

# Pasta monitorada para downloads (mapear volume Docker para pasta Downloads do host)
WATCH_FOLDER=/app/media/watch_downloads
